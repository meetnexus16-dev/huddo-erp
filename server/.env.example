# Copy to .env (production) and .env.development (local)
# npm start  → loads .env
# npm run dev → loads .env.development

PORT=8809
NODE_ENV=production

# Database
MONGO_URI=mongodb://localhost:27017/huddo-erp

# Public URLs
FRONTEND_URL=https://huddo.meetnexus.in
CLIENT_URL=https://huddo.meetnexus.in

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Configuration (For file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Nodemailer - e.g., Mailtrap, SendGrid, Gmail)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@huddoerp.com
SMTP_FROM_NAME="Huddo ERP Admin"

# SMS/WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
