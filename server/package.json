{
  "name": "huddo-erp-backend",
  "version": "1.0.0",
  "description": "Production-level Backend for Huddo Shoes Brand Management & Distribution System",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env.development --watch server.js",
    "seed": "node --env-file=.env.development seeds/databaseSeed.js",
    "init-db": "node --env-file=.env.development seeds/initFreshDb.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.10"
  }
}
